# ============================================================
#  POLYMARKET BOT — Configuración
#  Copia este archivo como .env y rellena tus valores
# ============================================================

# ── Tu clave privada de la wallet (Polygon/MetaMask) ────────
# ⚠️ NUNCA compartas esta clave con nadie
# Empieza con 0x y tiene 64 caracteres hexadecimales
PRIVATE_KEY=0xTU_CLAVE_PRIVADA_AQUI

# ── Red ─────────────────────────────────────────────────────
# 137  = Polygon Mainnet (dinero real)
# 80002 = Amoy Testnet  (para pruebas sin dinero real)
CHAIN_ID=137
POLYGON_RPC=https://polygon-rpc.com

# ── Modo seguro ─────────────────────────────────────────────
# DRY_RUN=true  → Solo muestra lo que haría, SIN ejecutar órdenes reales
# DRY_RUN=false → Ejecuta órdenes reales (¡usa dinero real!)
DRY_RUN=true

# ── Filtros de mercados ─────────────────────────────────────
# Volumen mínimo del mercado en USD para considerarlo
MIN_VOLUME_USD=50000
# Liquidez mínima en el order book (profundidad total) en USD
MIN_LIQUIDITY_USD=500
# No operar en mercados donde el precio YES sea mayor a MAX_PRICE
MAX_PRICE=0.90
# No operar en mercados donde el precio YES sea menor a MIN_PRICE
MIN_PRICE=0.10

# ── Estrategia: Imbalance del Order Book ────────────────────
# Si el 65%+ del volumen del order book está en un lado, entra en esa dirección
IMBALANCE_THRESHOLD=0.65
# Colocar la orden X céntimos mejor que el mejor precio del libro
PRICE_IMPROVEMENT=0.01

# ── Gestión de riesgo ───────────────────────────────────────
# Máximo que arriesgas por operación (en USDC)
MAX_POSITION_USDC=5.0
# Pérdida máxima diaria antes de que el bot se detenga (en USDC)
MAX_DAILY_LOSS_USDC=25.0
# Número máximo de posiciones abiertas al mismo tiempo
MAX_OPEN_POSITIONS=3
# Fracción de Kelly a usar (0.25 = 25% del Kelly completo, más conservador)
KELLY_FRACTION=0.25

# ── Configuración del bot ───────────────────────────────────
# Cada cuántos segundos escanea los mercados
SCAN_INTERVAL_SECONDS=300
# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
